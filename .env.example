# Snowflake MCP server connection config. Copy to `.env` and fill in.
# `.env` is gitignored — never commit real credentials.
SNOWFLAKE_ACCOUNT=your_account_identifier
SNOWFLAKE_USER=your_user
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_ROLE=ACCOUNTADMIN
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=AIRBNB
SNOWFLAKE_SCHEMA=dbt_schema

# Permission gate: read_only | read_write | full  (start read_only)
SNOWFLAKE_MCP_MODE=read_only
# Max rows returned per query
SNOWFLAKE_MCP_MAX_ROWS=1000
